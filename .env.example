# Required: Supabase project connection
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-publishable-or-anon-key

# Required: public application URL, without a trailing slash
# Local: http://localhost:3000
# Vercel: https://your-project.vercel.app
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Server-only: required by the admin dashboard and import API
# Never add NEXT_PUBLIC_ to this variable.
SUPABASE_SERVICE_ROLE_KEY=your-server-only-service-role-key

# Optional: required only by POST /api/import/listings
IMPORT_API_KEY=use-a-long-random-secret

# Server-only: comma-separated admin emails (optional)
ADMIN_EMAILS=kozmen25@gmail.com,ozmebomer9@gmail.com

# Server-only: required by /api/cron/daily, cron subroutes, and Vercel Cron
CRON_SECRET=use-another-long-random-secret

# Server-only: required for Instagram Reel autopublishing
INSTAGRAM_ACCESS_TOKEN=your-long-lived-instagram-user-access-token
INSTAGRAM_IG_USER_ID=your-instagram-business-account-id
INSTAGRAM_GRAPH_API_VERSION=v20.0

# Required by the Sahibinden adapter to bypass Cloudflare Managed Challenge.
# Get an API key from https://scrapingfish.com
# SCRAPINGFISH_API_KEY=your-scrapingfish-api-key
